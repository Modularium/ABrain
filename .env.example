# Copy to .env only when you need local overrides.
# The setup flow will create .env from this template if it is missing.

# Runtime directories
DATA_DIR=data
SESSIONS_DIR=data/sessions
VECTOR_DB_DIR=data/vectorstore
LOG_DIR=logs
MODELS_DIR=models
EMBEDDINGS_CACHE_DIR=embeddings_cache
EXPORT_DIR=export
MEMORY_LOG_DIR=data/memory_log
DEFAULT_STORE_BACKEND=memory
VECTOR_DB_BACKEND=memory
MEMORY_STORE_BACKEND=memory

# Core and gateway logging
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_JSON=false
AUTOTRAINER_FREQUENCY_HOURS=24

# LLM defaults
OPENAI_API_KEY=
LLM_BACKEND=openai
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# REST API gateway security and rate limiting
AUTH_ENABLED=false
API_AUTH_ENABLED=false
API_GATEWAY_KEY=
API_KEY_SCOPES=*
API_TOKENS=
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
RATE_LIMITS_ENABLED=true
RATE_LIMIT=60/minute
TIMEOUT_DEFAULT=10
CORS_ALLOW_ORIGINS=*
INPUT_LIMIT_BYTES=4096

# Optional bridge URLs used by legacy-compatible gateway routes
DISPATCHER_URL=http://dispatcher:8001
AGENT_REGISTRY_URL=http://registry:8002
LLM_GATEWAY_URL=http://llm_gateway:8003
VECTOR_STORE_URL=http://vector_store:8004
SESSION_MANAGER_URL=http://session_manager:8005

# Durable local runtime state
ABRAIN_APPROVAL_STORE_PATH=runtime/abrain_approvals.json
ABRAIN_PLAN_STATE_DB_PATH=runtime/abrain_plan_state.sqlite3
ABRAIN_TRACE_DB_PATH=runtime/abrain_traces.sqlite3
ABRAIN_PERF_HISTORY_PATH=runtime/abrain_perf_history.json
ABRAIN_TRAINING_DATASET_PATH=runtime/abrain_training_dataset.json

# Frontend defaults
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
