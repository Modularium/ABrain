#!/bin/bash
# Legacy compatibility wrapper for the canonical ABrain CLI.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ ! -f "$SCRIPT_DIR/abrain" ]]; then
    printf 'ABrain CLI nicht gefunden: %s/abrain\n' "$SCRIPT_DIR" >&2
    printf 'Der Legacy-Aufruf "agentnn" erwartet die kanonische CLI unter scripts/abrain.\n' >&2
    exit 1
fi

export ABRAIN_CLI_ALIAS="agentnn"
exec "$SCRIPT_DIR/abrain" "$@"
