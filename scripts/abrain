#!/bin/bash
# -*- coding: utf-8 -*-
# ABrain CLI Tool - Canonical command line interface for orchestration, diagnostics and system operations

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
CLI_NAME="abrain"
CLI_VERSION="$(tr -d '[:space:]' < "$REPO_ROOT/VERSION" 2>/dev/null || echo "1.0.0")"
ABRAIN_STATE_DIR="$REPO_ROOT/.abrain"
ABRAIN_CONFIG_FILE="$ABRAIN_STATE_DIR/config.json"
ABRAIN_STATUS_FILE="$ABRAIN_STATE_DIR/status.json"
ABRAIN_OUTPUT_FORMAT="${ABRAIN_OUTPUT_FORMAT:-text}"

source_if_exists() {
    local file="$1"
    if [[ -f "$file" ]]; then
        # shellcheck disable=SC1090
        source "$file"
    fi
}

source_if_exists "$SCRIPT_DIR/lib/log_utils.sh"
source_if_exists "$SCRIPT_DIR/lib/status_utils.sh"
source_if_exists "$SCRIPT_DIR/helpers/common.sh"

if [[ -t 1 ]]; then
    : "${BLUE:=$'\033[0;34m'}"
    : "${CYAN:=$'\033[0;36m'}"
    : "${GREEN:=$'\033[0;32m'}"
    : "${YELLOW:=$'\033[1;33m'}"
    : "${RED:=$'\033[0;31m'}"
    : "${NC:=$'\033[0m'}"
else
    : "${BLUE:=}"
    : "${CYAN:=}"
    : "${GREEN:=}"
    : "${YELLOW:=}"
    : "${RED:=}"
    : "${NC:=}"
fi

if ! declare -F log_info >/dev/null 2>&1; then
    log_info() { printf "[INFO] %s\n" "$*"; }
fi
if ! declare -F log_warn >/dev/null 2>&1; then
    log_warn() { printf "[WARN] %s\n" "$*"; }
fi
if ! declare -F log_err >/dev/null 2>&1; then
    log_err() { printf "[ERROR] %s\n" "$*" >&2; }
fi
if ! declare -F log_ok >/dev/null 2>&1; then
    log_ok() { printf "[OK] %s\n" "$*"; }
fi

resolve_runtime_dir() {
    echo "$ABRAIN_STATE_DIR"
}

current_config_file() {
    echo "$ABRAIN_CONFIG_FILE"
}

current_status_file() {
    echo "$ABRAIN_STATUS_FILE"
}

ensure_abrain_state_dir() {
    mkdir -p "$ABRAIN_STATE_DIR"
}

has_command() {
    command -v "$1" >/dev/null 2>&1
}

tool_version() {
    local tool="$1"

    if ! has_command "$tool"; then
        echo "nicht verfügbar"
        return 0
    fi

    case "$tool" in
        python3)
            python3 --version 2>/dev/null | cut -d' ' -f2
            ;;
        node)
            node --version 2>/dev/null
            ;;
        docker)
            docker --version 2>/dev/null | cut -d' ' -f3 | tr -d ','
            ;;
        poetry)
            poetry --version 2>/dev/null | grep -oE '[0-9]+(\.[0-9]+)+'
            ;;
        npm)
            npm --version 2>/dev/null
            ;;
        git)
            git --version 2>/dev/null | cut -d' ' -f3
            ;;
        *)
            echo "verfügbar"
            ;;
    esac
}

find_compose_file() {
    local search_paths=(
        "$REPO_ROOT/docker-compose.yml"
        "$REPO_ROOT/docker-compose.yaml"
        "$REPO_ROOT/deploy/docker-compose.yml"
        "$REPO_ROOT/deploy/docker-compose.yaml"
        "$REPO_ROOT/docker/docker-compose.yml"
        "$REPO_ROOT/docker/docker-compose.yaml"
    )

    local file
    for file in "${search_paths[@]}"; do
        if [[ -f "$file" ]]; then
            echo "$file"
            return 0
        fi
    done

    return 1
}

run_setup_script() {
    if [[ ! -f "$SCRIPT_DIR/setup.sh" ]]; then
        log_err "Setup-Skript nicht gefunden: $SCRIPT_DIR/setup.sh"
        exit 1
    fi

    exec "$SCRIPT_DIR/setup.sh" "$@"
}

find_python_for_control_plane() {
    local venv_python="$REPO_ROOT/.venv/bin/python"

    if [[ -x "$venv_python" ]]; then
        echo "$venv_python"
        return 0
    fi

    if has_command python3; then
        command -v python3
        return 0
    fi

    log_err "Python 3 ist nicht verfügbar"
    exit 1
}

run_control_plane_bridge() {
    local python_bin=""
    python_bin="$(find_python_for_control_plane)"

    PYTHONPATH="$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}" \
    ABRAIN_OUTPUT="$ABRAIN_OUTPUT_FORMAT" \
    exec "$python_bin" -m scripts.abrain_control "$@"
}

print_banner() {
    cat << EOF
${BLUE}
    _    ____            _       
   / \  | __ ) _ __ __ _(_)_ __  
  / _ \ |  _ \| '__/ _\` | | '_ \ 
 / ___ \| |_) | | | (_| | | | | |
/_/   \_\____/|_|  \__,_|_|_| |_|
${NC}
${CYAN}ABrain CLI v${CLI_VERSION} - orchestration, diagnostics and system operations${NC}
EOF
}

usage() {
    print_banner
    cat << EOF

Usage: ${CLI_NAME} <command> [options] [arguments]

SETUP & CONFIG:
  setup [step]           Vollstaendigen ABrain-Bootstrap ausfuehren; ohne Schritt = One-Liner-Setup
  config <action>        Konfiguration anzeigen, bearbeiten oder validieren

OPERATIONS:
  start [service]        Docker-Compose-Services starten
  stop [service]         Docker-Compose-Services stoppen
  restart [service]      Services neu starten
  logs <service>         Logs eines Services anzeigen
  deploy <target>        Lokales Deployment ausführen

DEVELOPER & OPERATIONS:
  task run ...           Task über den kanonischen Kernpfad auslösen
  plan run ...           Plan über den kanonischen Kernpfad auslösen
  plan list              Letzte Pläne und Planstatus anzeigen
  approval <action>      Pending approvals listen oder entscheiden
  trace <action>         Traces listen oder im Detail anzeigen
  explain <trace_id>     Explainability eines Trace anzeigen
  agent list             Registrierte Agenten aus dem Kern anzeigen
  health                 Kernstatus, Governance und Startpfade anzeigen
  reasoning labos <mode> Domain-Reasoning fuer LabOS (V2) ausfuehren

DIAGNOSTICS:
  status                 System- und Runtime-Status anzeigen
  validate               Grundlegende Validierung ausführen
  doctor [--fix]         Diagnose ausführen und optional reparieren
  repair                 Nicht-destruktive Standardreparaturen ausführen

QUALITY & MAINTENANCE:
  test [category]        Pytest-basierte Testläufe starten
  clean                  Cache- und Build-Artefakte bereinigen

GENERAL:
  version                Version und Build-Informationen anzeigen
  help [command]         Hilfe zu CLI oder Kommando anzeigen

GLOBAL OPTIONS:
  --verbose, -v          Ausführliche Ausgabe aktivieren
  --quiet, -q            Weniger Ausgabe
  --dry-run              Nur anzeigen, nicht ausführen
  --yes, -y              Bestätigungen automatisch annehmen
  --config FILE          Alternative Shell-Konfiguration laden
  --json                 Maschinenlesbare JSON-Ausgabe für Control-Plane-Kommandos
  --version              Kurzform für 'version'
  --help, -h             Kurzform für 'help'

BEISPIELE:
  ${CLI_NAME} help
  ${CLI_NAME} setup
  ${CLI_NAME} status --watch
  ${CLI_NAME} task run system_status "Check system health"
  ${CLI_NAME} approval list
  ${CLI_NAME} trace list --json
  ${CLI_NAME} config show
  ${CLI_NAME} test unit
  ${CLI_NAME} doctor --fix
  ${CLI_NAME} start

KONFIGURATION:
  Runtime-Pfad:          .abrain/

EOF
}

show_command_help() {
    local command="$1"

    case "$command" in
        setup)
            cat << EOF
${CYAN}${CLI_NAME} setup${NC} - ABrain-Umgebung einrichten

Usage: ${CLI_NAME} setup
       ${CLI_NAME} setup [step]

STANDARDVERHALTEN:
  Ohne Schritt wird der komplette kanonische Bootstrap ausgefuehrt:
  .venv, Python-Dependencies, editable Install, MCP-v2/API-Smokes und UI-Build.

SCHRITTE:
  env                   .venv anlegen/verwenden, pip-Tooling aktualisieren, .env erzeugen
  deps                  Python-Abhängigkeiten installieren
  cli                   Editable-Install und abrain-mcp-Entry-Point aktualisieren
  api                   API-Gateway import-smoke und Startpfad anzeigen
  mcp                   MCP-v2 initialize/tools/list smoke ausführen
  ui                    frontend/agent-ui per npm ci, type-check und build vorbereiten
  all                   kompletter Online-Bootstrap

HINWEIS:
  Das Kommando delegiert direkt an scripts/setup.sh. Es gibt keine separate
  Parallel-CLI und keine Abhängigkeit mehr auf historische Helper-Verzeichnisse.

BEISPIELE:
  ${CLI_NAME} setup
  ${CLI_NAME} setup deps
  ${CLI_NAME} setup cli
EOF
            ;;
        start)
            cat << EOF
${CYAN}${CLI_NAME} start${NC} - Docker-Compose-Services starten

Usage: ${CLI_NAME} start [service] [options]

STANDARDVERHALTEN:
  Ohne Service-Namen wird der komplette Compose-Stack gestartet.

OPTIONS:
  --build               Images vor dem Start neu bauen
  --foreground          Im Vordergrund starten

BEISPIELE:
  ${CLI_NAME} start
  ${CLI_NAME} start api
  ${CLI_NAME} start --build
EOF
            ;;
        status)
            cat << EOF
${CYAN}${CLI_NAME} status${NC} - Runtime-, Tool- und Konfigurationsstatus anzeigen

Usage: ${CLI_NAME} status [options]

OPTIONS:
  --watch               Status fortlaufend aktualisieren
  --interval SECONDS    Intervall für --watch (Standard: 5)

BEISPIELE:
  ${CLI_NAME} status
  ${CLI_NAME} status --watch
  ${CLI_NAME} status --interval 2
EOF
            ;;
        test)
            cat << EOF
${CYAN}${CLI_NAME} test${NC} - Pytest-basierte Testläufe ausführen

Usage: ${CLI_NAME} test [category] [pytest-options]

KATEGORIEN:
  unit                  Nur Unit-Tests
  integration           Integrationstests mit --run-integration
  fast                  Leichte Unit-Tests ohne Heavy-Marker
  all                   Gesamte Suite ohne zusätzliche Filter

BEISPIELE:
  ${CLI_NAME} test
  ${CLI_NAME} test integration
  ${CLI_NAME} test fast --skip-heavy
  ${CLI_NAME} test all --coverage
EOF
            ;;
        doctor)
            cat << EOF
${CYAN}${CLI_NAME} doctor${NC} - Diagnose und optionale Reparatur

Usage: ${CLI_NAME} doctor [--fix]

CHECKS:
  - Python-, Git- und optionale Tool-Verfügbarkeit
  - .env und Runtime-Konfiguration
  - kanonischer Runtime-Pfad .abrain

OPTIONEN:
  --fix                 .abrain anlegen und Standardreparaturen anwenden

BEISPIELE:
  ${CLI_NAME} doctor
  ${CLI_NAME} doctor --fix
EOF
            ;;
        config)
            cat << EOF
${CYAN}${CLI_NAME} config${NC} - Runtime-Konfiguration verwalten

Usage: ${CLI_NAME} config <show|edit|reset|validate>

VERHALTEN:
  Die CLI verwendet ausschliesslich .abrain/config.json.

BEISPIELE:
  ${CLI_NAME} config show
  ${CLI_NAME} config edit
  ${CLI_NAME} config validate
EOF
            ;;
        task)
            cat << EOF
${CYAN}${CLI_NAME} task${NC} - Task direkt ueber services/core.py starten

Usage: ${CLI_NAME} task run <task_type> [description] [options]

BEISPIELE:
  ${CLI_NAME} task run system_status "Check system health"
  ${CLI_NAME} task run code_review --input path=services/core.py
  ${CLI_NAME} task run system_status --json

HINWEIS:
  Dieses Kommando ist eine duenne Kontrollschicht ueber den kanonischen
  Kernpfad. Fuer Details siehe '${CLI_NAME} task run --help'.
EOF
            ;;
        plan)
            cat << EOF
${CYAN}${CLI_NAME} plan${NC} - Planpfade ueber den kanonischen Kern ansprechen

Usage: ${CLI_NAME} plan run <task_type> [description] [options]
       ${CLI_NAME} plan list [options]

BEISPIELE:
  ${CLI_NAME} plan run workflow_automation "Trigger deployment workflow"
  ${CLI_NAME} plan list
  ${CLI_NAME} plan list --json
EOF
            ;;
        approval)
            cat << EOF
${CYAN}${CLI_NAME} approval${NC} - Pending approvals einsehen und entscheiden

Usage: ${CLI_NAME} approval list [options]
       ${CLI_NAME} approval approve <approval_id> [options]
       ${CLI_NAME} approval reject <approval_id> [options]

BEISPIELE:
  ${CLI_NAME} approval list
  ${CLI_NAME} approval approve approval-123 --comment "safe"
  ${CLI_NAME} approval reject approval-123 --comment "blocked"
EOF
            ;;
        trace)
            cat << EOF
${CYAN}${CLI_NAME} trace${NC} - Traces aus dem kanonischen Trace-Store lesen

Usage: ${CLI_NAME} trace list [options]
       ${CLI_NAME} trace show <trace_id> [options]

BEISPIELE:
  ${CLI_NAME} trace list
  ${CLI_NAME} trace show trace-123
  ${CLI_NAME} explain trace-123
EOF
            ;;
        explain)
            cat << EOF
${CYAN}${CLI_NAME} explain${NC} - Explainability fuer einen Trace anzeigen

Usage: ${CLI_NAME} explain <trace_id> [options]

BEISPIELE:
  ${CLI_NAME} explain trace-123
  ${CLI_NAME} explain trace-123 --json
EOF
            ;;
        agent)
            cat << EOF
${CYAN}${CLI_NAME} agent${NC} - Agent-Katalog des kanonischen Kerns inspizieren

Usage: ${CLI_NAME} agent list [options]

BEISPIELE:
  ${CLI_NAME} agent list
  ${CLI_NAME} agent list --json
EOF
            ;;
        health)
            cat << EOF
${CYAN}${CLI_NAME} health${NC} - Kernstatus, Governance und Startpfade anzeigen

Usage: ${CLI_NAME} health [options]

BEISPIELE:
  ${CLI_NAME} health
  ${CLI_NAME} health --json
EOF
            ;;
        *)
            echo "Keine detaillierte Hilfe für '$command' verfügbar."
            echo "Verwende '${CLI_NAME} help' für eine Übersicht aller Kommandos."
            ;;
    esac
}

show_version() {
    echo "${CYAN}ABrain CLI${NC} v${CLI_VERSION}"
    echo
    echo "Build-Informationen:"
    echo "  Repository: $REPO_ROOT"
    echo "  Branch: $(git -C "$REPO_ROOT" branch --show-current 2>/dev/null || echo 'Unbekannt')"
    echo "  Commit: $(git -C "$REPO_ROOT" rev-parse --short HEAD 2>/dev/null || echo 'Unbekannt')"
    echo "  Build-Zeit: $(date)"
    echo
    echo "Runtime:"
    echo "  Primärer CLI-Name: ${CLI_NAME}"
    echo "  Runtime-Verzeichnis: $(resolve_runtime_dir)"
    echo "  Konfigurationsdatei: $(current_config_file)"
    echo
    echo "Verfügbare Tools:"
    local tools=(python3 git node docker poetry npm)
    local tool
    for tool in "${tools[@]}"; do
        if has_command "$tool"; then
            printf "  ${GREEN}%-8s${NC} %s\n" "$tool" "$(tool_version "$tool")"
        else
            printf "  ${RED}%-8s${NC} %s\n" "$tool" "nicht verfügbar"
        fi
    done
}

print_status_snapshot() {
    local compose_file=""
    local config_file
    local status_file

    config_file="$(current_config_file)"
    status_file="$(current_status_file)"
    compose_file="$(find_compose_file 2>/dev/null || true)"

    print_banner
    echo
    echo "Repository:           $REPO_ROOT"
    echo "Runtime-Verzeichnis:  $(resolve_runtime_dir)"
    echo "Konfiguration:        $config_file"
    echo "Status-Datei:         $status_file"
    echo ".env:                 $([[ -f "$REPO_ROOT/.env" ]] && echo vorhanden || echo nicht\ gefunden)"
    echo "Compose-Datei:        ${compose_file:-nicht gefunden}"
    echo
    echo "Tooling:"
    printf "  %-10s %s\n" "python3" "$(tool_version python3)"
    printf "  %-10s %s\n" "git" "$(tool_version git)"
    printf "  %-10s %s\n" "node" "$(tool_version node)"
    printf "  %-10s %s\n" "docker" "$(tool_version docker)"
    printf "  %-10s %s\n" "poetry" "$(tool_version poetry)"
    echo
}

run_validation_checks() {
    local verbose="${1:-false}"
    local failed=0

    if [[ ! -d "$REPO_ROOT" ]]; then
        log_err "Repository-Verzeichnis nicht verfügbar: $REPO_ROOT"
        failed=1
    fi

    if has_command python3; then
        [[ "$verbose" == "true" ]] && log_ok "Python gefunden: $(tool_version python3)"
    else
        log_err "Python 3 fehlt"
        failed=1
    fi

    if has_command git; then
        [[ "$verbose" == "true" ]] && log_ok "Git gefunden: $(tool_version git)"
    else
        log_err "Git fehlt"
        failed=1
    fi

    if [[ -f "$REPO_ROOT/.env" ]]; then
        [[ "$verbose" == "true" ]] && log_ok ".env vorhanden"
    else
        log_warn ".env fehlt"
    fi

    if [[ -f "$ABRAIN_CONFIG_FILE" ]]; then
        [[ "$verbose" == "true" ]] && log_ok ".abrain/config.json vorhanden"
    else
        log_warn "Keine Runtime-Konfiguration gefunden"
    fi

    if has_command docker; then
        [[ "$verbose" == "true" ]] && log_ok "Docker gefunden: $(tool_version docker)"
    else
        log_warn "Docker nicht verfügbar"
    fi

    if has_command poetry; then
        [[ "$verbose" == "true" ]] && log_ok "Poetry gefunden: $(tool_version poetry)"
    else
        log_warn "Poetry nicht verfügbar"
    fi

    return "$failed"
}

cmd_setup() {
    run_setup_script "$@"
}

cmd_task() {
    run_control_plane_bridge task "$@"
}

cmd_plan() {
    run_control_plane_bridge plan "$@"
}

cmd_approval() {
    run_control_plane_bridge approval "$@"
}

cmd_trace() {
    run_control_plane_bridge trace "$@"
}

cmd_explain() {
    run_control_plane_bridge explain "$@"
}

cmd_agent() {
    run_control_plane_bridge agent "$@"
}

cmd_health() {
    run_control_plane_bridge health "$@"
}

cmd_reasoning() {
    run_control_plane_bridge reasoning "$@"
}

cmd_start() {
    local service=""
    local compose_file=""
    local -a compose_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --build)
                compose_args+=("--build")
                shift
                ;;
            --foreground)
                shift
                ;;
            --help|-h)
                show_command_help start
                exit 0
                ;;
            --*)
                log_err "Unbekannte Start-Option: $1"
                exit 1
                ;;
            *)
                if [[ -z "$service" ]]; then
                    service="$1"
                else
                    log_err "Nur ein Service-Name wird unterstützt"
                    exit 1
                fi
                shift
                ;;
        esac
    done

    if ! has_command docker; then
        log_err "Docker ist nicht verfügbar"
        exit 1
    fi

    if ! compose_file="$(find_compose_file)"; then
        log_err "Keine docker-compose-Datei gefunden"
        exit 1
    fi

    compose_args+=("-d")

    if [[ -n "$service" && "$service" != "all" && "$service" != "standard" ]]; then
        compose_args+=("$service")
    fi

    log_info "Starte Compose-Stack aus $(basename "$compose_file")"
    (
        cd "$(dirname "$compose_file")"
        exec docker compose -f "$compose_file" up "${compose_args[@]}"
    )
}

cmd_stop() {
    local service="${1:-all}"
    local compose_file=""

    if ! has_command docker; then
        log_err "Docker ist nicht verfügbar"
        exit 1
    fi

    if ! compose_file="$(find_compose_file)"; then
        log_err "Keine docker-compose-Datei gefunden"
        exit 1
    fi

    if [[ "$service" == "all" || "$service" == "standard" ]]; then
        (
            cd "$(dirname "$compose_file")"
            exec docker compose -f "$compose_file" down
        )
    else
        (
            cd "$(dirname "$compose_file")"
            exec docker compose -f "$compose_file" stop "$service"
        )
    fi
}

cmd_restart() {
    local service="${1:-all}"
    shift || true
    cmd_stop "$service"
    sleep 1
    cmd_start "$service" "$@"
}

cmd_status() {
    local watch=false
    local interval=5

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --watch)
                watch=true
                shift
                ;;
            --interval)
                interval="${2:-5}"
                shift 2
                ;;
            --help|-h)
                show_command_help status
                exit 0
                ;;
            *)
                log_err "Unbekannte Status-Option: $1"
                exit 1
                ;;
        esac
    done

    if [[ "$watch" == "true" ]]; then
        while true; do
            clear
            print_status_snapshot
            sleep "$interval"
        done
    fi

    print_status_snapshot
}

cmd_test() {
    local category="unit"
    local -a pytest_args=()
    local python_bin="python3"

    if [[ $# -gt 0 && "${1}" != --* ]]; then
        category="$1"
        shift
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --coverage)
                pytest_args+=("--cov=.")
                shift
                ;;
            --help|-h)
                show_command_help test
                exit 0
                ;;
            *)
                pytest_args+=("$1")
                shift
                ;;
        esac
    done

    if [[ -x "$REPO_ROOT/.venv/bin/python" ]]; then
        python_bin="$REPO_ROOT/.venv/bin/python"
    elif ! has_command python3; then
        log_err "Python 3 ist nicht verfügbar"
        exit 1
    fi

    case "$category" in
        unit)
            pytest_args=("-m" "unit" "${pytest_args[@]}")
            ;;
        integration)
            pytest_args=("--run-integration" "-m" "integration" "${pytest_args[@]}")
            ;;
        fast)
            pytest_args=("--skip-heavy" "-m" "unit and not heavy" "${pytest_args[@]}")
            ;;
        all)
            ;;
        *)
            log_err "Unbekannte Test-Kategorie: $category"
            exit 1
            ;;
    esac

    log_info "Starte Tests (${category})"
    exec "$python_bin" -m pytest "${pytest_args[@]}"
}

cmd_validate() {
    if run_validation_checks true; then
        log_ok "Validierung abgeschlossen"
    else
        exit 1
    fi
}

cmd_repair() {
    ensure_abrain_state_dir

    if [[ ! -f "$REPO_ROOT/.env" && -f "$REPO_ROOT/.env.example" ]]; then
        cp "$REPO_ROOT/.env.example" "$REPO_ROOT/.env"
        log_ok ".env aus .env.example erstellt"
    fi

    log_ok "Standardreparaturen abgeschlossen"
}

cmd_logs() {
    local service="${1:-}"
    local compose_file=""
    shift || true

    if [[ -z "$service" ]]; then
        log_err "Service-Name erforderlich"
        echo "Verwendung: ${CLI_NAME} logs <service> [optionen]"
        exit 1
    fi

    if ! has_command docker; then
        log_err "Docker ist nicht verfügbar"
        exit 1
    fi

    if ! compose_file="$(find_compose_file)"; then
        log_err "Keine docker-compose-Datei gefunden"
        exit 1
    fi

    (
        cd "$(dirname "$compose_file")"
        if [[ "$service" == "all" ]]; then
            exec docker compose -f "$compose_file" logs "$@"
        else
            exec docker compose -f "$compose_file" logs "$service" "$@"
        fi
    )
}

cmd_clean() {
    local targets=(
        "$REPO_ROOT/.pytest_cache"
        "$REPO_ROOT/__pycache__"
        "$REPO_ROOT/frontend/dist"
        "$REPO_ROOT/frontend/build"
        "$REPO_ROOT/dist"
        "$REPO_ROOT/build"
    )

    local target
    for target in "${targets[@]}"; do
        if [[ -e "$target" ]]; then
            rm -rf "$target"
            log_ok "Entfernt: $target"
        fi
    done
}

cmd_deploy() {
    local target="${1:-local}"

    case "$target" in
        local)
            cmd_start
            ;;
        staging|production)
            log_err "Deployment-Ziel '$target' ist in dieser Bash-CLI nicht implementiert"
            exit 1
            ;;
        *)
            log_err "Unbekanntes Deployment-Ziel: $target"
            exit 1
            ;;
    esac
}

cmd_config() {
    local action="${1:-show}"
    shift || true
    local config_file
    config_file="$(current_config_file)"

    case "$action" in
        show)
            echo "=== ABrain Konfiguration ==="
            echo "Runtime-Verzeichnis: $(resolve_runtime_dir)"
            echo
            if [[ -f "$REPO_ROOT/.env" ]]; then
                echo "📄 .env"
                grep -v '^#' "$REPO_ROOT/.env" | grep -v '^$' || echo "  (leer)"
            else
                echo "❌ .env nicht gefunden"
            fi
            echo
            if [[ -f "$config_file" ]]; then
                echo "📄 Runtime-Konfiguration: $config_file"
                sed -n '1,20p' "$config_file"
            else
                echo "❌ Keine Runtime-Konfiguration gefunden"
                echo "   Erwartet: $ABRAIN_CONFIG_FILE"
            fi
            ;;
        edit)
            ensure_abrain_state_dir
            local editor="${EDITOR:-nano}"
            touch "$ABRAIN_CONFIG_FILE"
            exec "$editor" "$ABRAIN_CONFIG_FILE"
            ;;
        reset)
            if [[ -f "$REPO_ROOT/.env.example" ]]; then
                cp "$REPO_ROOT/.env.example" "$REPO_ROOT/.env"
                log_ok ".env aus .env.example zurückgesetzt"
            else
                log_err ".env.example nicht gefunden"
                exit 1
            fi
            ;;
        validate)
            cmd_validate "$@"
            ;;
        *)
            log_err "Unbekannte Config-Aktion: $action"
            echo "Verfügbare Aktionen: show, edit, reset, validate"
            exit 1
            ;;
    esac
}

cmd_doctor() {
    local fix_mode=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --fix)
                fix_mode=true
                shift
                ;;
            --help|-h)
                show_command_help doctor
                exit 0
                ;;
            *)
                log_err "Unbekannte Doctor-Option: $1"
                exit 1
                ;;
        esac
    done

    log_info "Führe ABrain-Diagnose aus..."
    if run_validation_checks true; then
        log_ok "Keine kritischen Probleme gefunden"
        return 0
    fi

    if [[ "$fix_mode" == "true" ]]; then
        log_info "Wende Standardreparaturen an..."
        cmd_repair
        return 0
    fi

    echo
    echo "Führe '${CLI_NAME} doctor --fix' aus, um Standardreparaturen anzuwenden."
    return 1
}

main() {
    local config_file=""
    local args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --verbose|-v)
                export DEBUG=1
                shift
                ;;
            --quiet|-q)
                export QUIET=1
                shift
                ;;
            --dry-run)
                export DRY_RUN=1
                shift
                ;;
            --yes|-y)
                export AUTO_MODE=true
                shift
                ;;
            --config)
                config_file="${2:-}"
                shift 2
                ;;
            --json)
                ABRAIN_OUTPUT_FORMAT="json"
                export ABRAIN_OUTPUT_FORMAT
                shift
                ;;
            --version)
                show_version
                exit 0
                ;;
            --help|-h)
                if [[ ${#args[@]} -eq 0 ]]; then
                    usage
                else
                    show_command_help "${args[0]}"
                fi
                exit 0
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done

    if [[ -n "$config_file" ]]; then
        if [[ -f "$config_file" ]]; then
            # shellcheck disable=SC1090
            source "$config_file"
        else
            log_err "Konfigurationsdatei nicht gefunden: $config_file"
            exit 1
        fi
    fi

    if [[ ${#args[@]} -eq 0 ]]; then
        usage
        exit 1
    fi

    local command="${args[0]}"
    local command_args=("${args[@]:1}")

    case "$command" in
        setup)
            cmd_setup "${command_args[@]}"
            ;;
        start)
            cmd_start "${command_args[@]}"
            ;;
        task)
            cmd_task "${command_args[@]}"
            ;;
        plan)
            cmd_plan "${command_args[@]}"
            ;;
        approval)
            cmd_approval "${command_args[@]}"
            ;;
        trace)
            cmd_trace "${command_args[@]}"
            ;;
        explain)
            cmd_explain "${command_args[@]}"
            ;;
        agent)
            cmd_agent "${command_args[@]}"
            ;;
        health)
            cmd_health "${command_args[@]}"
            ;;
        reasoning)
            cmd_reasoning "${command_args[@]}"
            ;;
        stop)
            cmd_stop "${command_args[@]}"
            ;;
        restart)
            cmd_restart "${command_args[@]}"
            ;;
        status)
            cmd_status "${command_args[@]}"
            ;;
        test)
            cmd_test "${command_args[@]}"
            ;;
        validate)
            cmd_validate "${command_args[@]}"
            ;;
        repair)
            cmd_repair "${command_args[@]}"
            ;;
        logs)
            cmd_logs "${command_args[@]}"
            ;;
        clean)
            cmd_clean "${command_args[@]}"
            ;;
        deploy)
            cmd_deploy "${command_args[@]}"
            ;;
        config)
            cmd_config "${command_args[@]}"
            ;;
        doctor)
            cmd_doctor "${command_args[@]}"
            ;;
        version)
            show_version
            ;;
        help)
            if [[ ${#command_args[@]} -gt 0 ]]; then
                show_command_help "${command_args[0]}"
            else
                usage
            fi
            ;;
        *)
            log_err "Unbekanntes Kommando: $command"
            echo "Verwende '${CLI_NAME} help' für eine Übersicht aller Kommandos."
            exit 1
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
